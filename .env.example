# Core
NODE_ENV=production
PORT=4000

# Security
JWT_SECRET=replace_with_min_32_chars_secret_value
# Solo para desbloqueo temporal: usar true permite JWT < 32 en produccion
ALLOW_WEAK_JWT_SECRET=false
CORS_ORIGINS=https://tu-frontend.com,https://admin.tu-frontend.com
TRUST_PROXY=1
HTTP_LOGS_ENABLED=false
JSON_BODY_LIMIT=1mb

# Database
DATABASE_URL=postgresql://user:password@host:5432/database

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
